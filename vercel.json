{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 10 // Limite de tempo para a função serverless (em segundos)
      }
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "arquivos.html",
      "use": "@vercel/static"
    },
    {
      "src": "setores.html",
      "use": "@vercel/static"
    },
    {
      "src": "staff.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    },
    {
      "src": "img/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*\\.(?:html|css|js|png|jpg|jpeg|svg|webp|ico))$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}